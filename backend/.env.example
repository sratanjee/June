# Copy to .env and fill in. .env is git-ignored.

# Anthropic — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase local Postgres (from `supabase start` output, "DB URL" line).
# Example: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# Server
PORT=4000
HOST=0.0.0.0

# Plaid Sandbox — get from https://dashboard.plaid.com → Developers → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Comma-separated. Default is good for Phase 1.
PLAID_PRODUCTS=auth,transactions,liabilities
PLAID_COUNTRY_CODES=US
# 32-byte hex (64 hex chars) used to AES-256-GCM encrypt Plaid access tokens at rest.
# If empty, a random key is generated at startup and a warning is logged — but the
# key must be set durably for any non-dev environment (rotating it invalidates
# existing stored tokens).
PLAID_TOKEN_ENC_KEY=

# Supabase Auth — find in https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://aejmtjgikqqqflhtynip.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for the morning cron job to call POST /jobs/morning-sync-and-checkin.
# Generate with: openssl rand -hex 24
# Set in Fly with: fly secrets set JOB_KEY=...
JOB_KEY=

# Public URL Plaid will POST webhooks to. In production, point at the Fly app.
# Example: https://june-jy5ddq.fly.dev/plaid/webhook
PLAID_WEBHOOK_URL=
